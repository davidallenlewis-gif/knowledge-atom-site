---
import BaseLayout from '../layouts/BaseLayout.astro';
import BackToExplainer from '../components/BackToExplainer.astro';
import GoDeeperDoor from '../components/GoDeeperDoor.astro';
import AtomFieldExplorer from '../components/AtomFieldExplorer.tsx';
import '../styles/l1.css';
---

<BaseLayout title="Anatomy of an Atom — The Knowledge Atom" layer="L1">
  <main class="l1-page">
    <div class="wrap">
      <BackToExplainer />

      <div class="l1-header">
        <div class="eyebrow">Layer 01 — Anatomy</div>
        <h1 class="l1-title">The atom is not a course.<br />It's a <em>structure.</em></h1>
        <p class="l1-deck">
          Every atom carries 19 fields across four clusters. Select a cluster in the diagram
          to see its fields, what each one holds in the specimen atom, and why it exists.
        </p>
      </div>

      <AtomFieldExplorer client:visible />

      <GoDeeperDoor href="/example" layer="L2" label="See a full worked example" />
    </div>
  </main>
</BaseLayout>
