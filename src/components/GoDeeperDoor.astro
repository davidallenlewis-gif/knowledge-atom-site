---
export interface Props {
  href: string;
  layer: string;
  label: string;
}
const { href, layer, label } = Astro.props;
---
<div class="go-deeper-door">
  <a href={href} class="go-deeper-link">
    <span class="go-deeper-label">{label}</span>
    <span class="go-deeper-arrow">{layer} →</span>
  </a>
</div>

<style>
  .go-deeper-door {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .go-deeper-link {
    display: inline-flex; align-items: center; gap: 14px;
    font-family: var(--mono); font-size: 12px; letter-spacing: .1em;
    color: var(--cyan-deep); text-decoration: none;
    text-transform: uppercase; transition: gap .2s;
  }
  .go-deeper-link:hover { gap: 20px; }
  .go-deeper-arrow { opacity: .7; }
</style>
