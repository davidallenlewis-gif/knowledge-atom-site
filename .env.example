# Required for live Claude generation (v2 — not used in v1)
ANTHROPIC_API_KEY=

# Set by Railway automatically
PORT=4321

# --- v2 Claude API upgrade ---
# 1. Set ANTHROPIC_API_KEY above
# 2. Uncomment the Anthropic SDK block in src/pages/api/generate-variation.ts
# 3. Change <FormatSwitcher mode="static" /> to mode="live" in index.astro and example.astro
# No other changes needed.
